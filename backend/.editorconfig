root = true

# All files
[*]
charset = utf-8

# EF Core generated migrations — suppress all analysis
[**/Migrations/**.cs]
generated_code = true
dotnet_analyzer_diagnostic.severity = none

# DTOs are grouped in a single file per feature by convention
[**/*Dtos.cs]
dotnet_diagnostic.MA0048.severity = none

# EF Core entity type configurations use long fluent methods by design
[**/Database/Configuration/**.cs]
dotnet_diagnostic.MA0051.severity = none

[*.cs]
dotnet_diagnostic.CA2007.severity = none
dotnet_diagnostic.MA0004.severity = none
dotnet_diagnostic.CA1812.severity = none
dotnet_diagnostic.CA1515.severity = none
dotnet_diagnostic.CA1062.severity = none
dotnet_diagnostic.CA1002.severity = none
dotnet_diagnostic.MA0016.severity = none
