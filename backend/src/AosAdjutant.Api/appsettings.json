{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "OTLP": {
    "Metrics": {
      "ExportIntervalMilliseconds": 60000
    }
  },
  "Authentication": {
    "RequireHttpsMetadata": true
  }
}
